ik_halo_hd.create_zip_halo_display(60)\nhaloDisplay.set_brightness(50)\n\ndef on_forever():\n    basic.show_string(\"Stuart\")\nbasic.forever(on_forever)\n","pxt.json":"{\n    \"name\": \"Luminate - Halo - Stuart Noble\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"pxt-kitronik-halohd\": \"github:kitronikltd/pxt-kitronik-halohd#v0.2.5\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"targetVersions\": {\n        \"branch\": \"v5.0.12\",\n        \"tag\": \"v5.0.12\",\n        \"commits\": \"https://github.com/microsoft/pxt-microbit/commits/97491d6832cccab6b5bdc05b58e4c6b5dcc18cdd\",\n        \"target\": \"5.0.12\",\n        \"pxt\": \"8.0.7\"\n    },\n    \"preferredEditor\": \"blocksprj\"\n}\n"}}],"shares":[],"lastSaveTime":1773438103344}